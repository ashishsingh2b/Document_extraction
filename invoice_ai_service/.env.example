# Application
APP_NAME="Invoice Intelligence Microservice"
DEBUG=False

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=invoice-uploads
MINIO_SECURE=False

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invoice_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# IRP Portal (e-Invoice) - Production credentials
IRP_BASE_URL=https://einvoice1.gst.gov.in
IRP_USERNAME=your_irp_username
IRP_PASSWORD=your_irp_password

# Tesseract OCR (if not in PATH)
# TESSERACT_CMD=/usr/bin/tesseract

# Logging
LOG_LEVEL=INFO

# Hybrid extraction (see ARCHITECTURE_AND_TRAINING_PLAN.md)
# AUTO_LEARN_ON_UPLOAD=false  # true only in dev: cache OCR + refresh patterns per upload
# ML_SIGNALS_ON_UPLOAD=true   # attach XGBoost routing scores to upload response
# ML_MODEL_DIR=models/v1
# TRAIN_API_SECRET=change-me-in-production
# UPLOAD_API_KEY=change-me-in-production
# DEFAULT_OCR_ENGINE=paddleocr
